{
  "manifest_version": 3,
  "name": "WebAI Extension",
  "description": "Unlock Chrome’s Built-In AI. Monitor local model readiness, inspect APIs, and debug your on-device AI natively in DevTools.",
  "version": "0.2.2",
  "action": {
    "default_popup": "",
    "default_icon": "assets/images/icon.png"
  },
  "icons": {
    "128": "assets/images/icon.png"
  },
  "permissions": [
    "system.cpu",
    "system.memory"
  ],
  "host_permissions": ["https://web-ai.studio/*", "http://localhost:8200/"],
  "devtools_page": "devtools-loader.html",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/images/spark.png",
        "injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
