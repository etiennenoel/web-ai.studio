{
  "manifest_version": 3,
  "name": "WebAI Extension",
  "description": "Unlock Chrome’s Built-In AI. Monitor local model readiness, inspect APIs, and debug your on-device AI natively in DevTools.",
  "version": "0.6.0",
  "action": {
    "default_icon": "assets/images/icon.png"
  },
  "side_panel": {
    "default_path": "side-panel/index.html"
  },
  "icons": {
    "128": "assets/images/icon.png"
  },
  "permissions": [
    "system.cpu",
    "system.memory",
    "sidePanel"
  ],
  "devtools_page": "devtools-loader.html",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/images/spark.png",
        "injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
